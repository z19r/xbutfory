<div class="c-utility-bar">
  <div class="c-utility-bar__inner">
    <span class="c-utility-bar__issue">
      <span class="c-utility-bar__live-dot"></span>
      <%= @issue %>
    </span>
    <span class="c-utility-bar__links">
      <span class="c-utility-bar__theme" data-controller="theme" data-theme-open-value="false" role="group" aria-label="Accent color">
        <button type="button"
                class="c-utility-bar__theme-toggle"
                data-theme-target="toggle"
                data-action="click->theme#toggleTray"
                aria-expanded="false"
                aria-label="Choose accent color"
                title="Theme">‹</button>
        <span class="c-utility-bar__theme-tray" data-theme-target="tray">
        <% accents.each do |a| %>
          <button type="button"
                  class="c-utility-bar__swatch<%= " c-utility-bar__swatch--on" if a[:key] == active_accent %>"
                  style="--swatch: <%= accent_var(a[:key]) %>"
                  title="<%= a[:label] %>"
                  aria-label="<%= a[:label] %> accent"
                  aria-pressed="<%= a[:key] == active_accent ? "true" : "false" %>"
                  data-theme-target="swatch"
                  data-theme-key-param="<%= a[:key] %>"
                  data-theme-value-param="<%= accent_var(a[:key]) %>"
                  data-action="click->theme#select"></button>
        <% end %>
        </span>
      </span>
      <span data-controller="after-dark">
        <% if current_user %>
          <button class="c-utility-bar__after-dark" data-after-dark-target="button" data-action="click->after-dark#toggle">🌙 After Dark</button>
        <% else %>
          <button
            class="c-utility-bar__after-dark c-utility-bar__after-dark--locked"
            type="button"
            aria-disabled="true"
            title="Show NSFW — sign in to unlock After Dark"
            data-action="click->after-dark#promptSignIn"
          >🌙 After Dark</button>
        <% end %>
      </span>
      <% if current_user %>
        <%= render AccountMenuComponent.new(handle: current_user.handle, admin: current_user.admin?, avatar_thumb: current_user.avatar_thumb) %>
      <% else %>
        <a href="/sign_in" class="c-utility-bar__link">Sign in</a>
        <a href="/sign_up" class="c-utility-bar__link c-utility-bar__link--strong">Create account</a>
      <% end %>
    </span>
  </div>
</div>
