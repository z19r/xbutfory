<div class="<%= card_classes %>">
  <% if pinned? %>
    <div class="c-card__ribbon"><span>★ PINNED SPONSOR</span><span class="c-card__ribbon-r2">FEATURED PLACEMENT</span></div>
  <% end %>
  <div class="c-card__row">
    <button class="<%= vote_classes %>" aria-label="Vote for <%= @x %> but for <%= @y %>">
      <span class="c-card__caret">▲</span>
      <span class="c-card__num"><%= @votes %></span>
      <span class="c-card__vlbl">VOTES</span>
    </button>
    <div class="c-card__body">
      <div class="c-card__titlerow">
        <% unless pinned? %>
          <% if @index %>
            <span class="c-card__idx">#<%= @index.to_s.rjust(3, '0') %></span>
          <% end %>
        <% end %>
        <span class="c-card__title">
          <% if @slug %>
            <%= link_to detail_path, class: "c-card__title-link" do %><%= @x %><span class="c-card__conn"> but for </span><%= @y %><% end %>
          <% else %>
            <%= @x %><span class="c-card__conn"> but for </span><%= @y %>
          <% end %>
        </span>
        <% if @stamp %>
          <%= render StampComponent.new(variant: @stamp) %>
        <% end %>
      </div>
      <p class="c-card__desc"><%= @description %></p>
      <div class="c-card__foot">
        <% if spotlight? %>
          <span class="c-card__tag c-card__tag--spon">SPONSORED</span>
        <% end %>
        <% if @category_label %>
          <span class="c-card__tag" style="color: var(--cat-<%= @category %>); border-color: color-mix(in srgb, var(--cat-<%= @category %>) 45%, transparent)"><%= @category_label.upcase %></span>
        <% end %>
        <span class="c-card__meta">submitted by @<%= @submitter %> · <%= @ago %></span>
        <%= link_to "visit site →", @url, class: "c-card__visit #{'c-card__visit--spon' if @sponsored}", target: "_blank", rel: "noopener" %>
      </div>
    </div>
  </div>
</div>
