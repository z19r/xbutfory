<div class="c-stat-block">
  <div class="c-stat-block__stat">
    <span class="c-stat-block__number"><%= @new_today %></span>
    <span class="c-stat-block__label">New Today</span>
  </div>
  <div class="c-stat-block__stat">
    <span class="c-stat-block__number"><%= @total_entries %></span>
    <span class="c-stat-block__label">Total Entries</span>
  </div>
  <div class="c-stat-block__stat">
    <span class="c-stat-block__number"><%= @total_votes %></span>
    <span class="c-stat-block__label">Total Votes</span>
  </div>
</div>
