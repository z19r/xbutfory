<div class="c-toast" data-controller="toast" data-toast-target="container" role="status" aria-live="polite" hidden>
  <span class="c-toast__message" data-toast-target="message"><%= @message %></span>
  <button class="c-toast__dismiss" data-action="click->toast#dismiss" aria-label="Dismiss">×</button>
</div>
