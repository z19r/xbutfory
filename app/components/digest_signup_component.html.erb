<section class="c-digest" data-controller="digest-signup">
  <% if @title.present? %>
    <div class="c-digest__title"><%= @title %></div>
  <% end %>
  <p class="c-digest__pitch"><%= @pitch %></p>
  <%= form_with url: helpers.digest_subscriptions_path,
                class: "c-digest__form",
                data: { action: "turbo:submit-end->digest-signup#subscribed" } do |f| %>
    <%= f.email_field :email,
          value: @prefill_email,
          class: "c-digest__input",
          placeholder: @placeholder,
          autocomplete: "email",
          required: true,
          data: { digest_signup_target: "email" } %>
    <button type="submit" class="c-digest__cta <%= 'c-digest__cta--gel' if @gel %>"><%= @cta %></button>
  <% end %>
</section>
