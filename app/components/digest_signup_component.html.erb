<section class="c-digest" data-controller="digest-signup">
  <% if @title.present? %>
    <div class="c-digest__title"><%= @title %></div>
  <% end %>
  <p class="c-digest__pitch"><%= @pitch %></p>
  <form class="c-digest__form" data-action="submit->digest-signup#subscribe">
    <input
      type="email"
      name="email"
      class="c-digest__input"
      placeholder="<%= @placeholder %>"
      autocomplete="email"
      data-digest-signup-target="email"
      required
    >
    <button type="submit" class="c-digest__cta <%= 'c-digest__cta--gel' if @gel %>"><%= @cta %></button>
  </form>
</section>
