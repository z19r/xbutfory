<div class="c-search-input" data-controller="search-filter">
  <span class="c-search-input__icon" aria-hidden="true">⚲</span>
  <input
    type="text"
    class="c-search-input__field"
    placeholder="<%= @placeholder %>"
    value="<%= @value %>"
    autocomplete="off"
    data-search-filter-target="input"
    data-action="input->search-filter#search"
  >
</div>
