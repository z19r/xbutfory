<p>Another week, another pile of launches. Here's what the index caught:</p>

<ul>
  <% @entries.each do |entry| %>
    <li>
      <%= link_to entry.title, entry_url(slug: entry.slug) %>
      <% if entry.description.present? %>&mdash; <%= entry.description %><% end %>
    </li>
  <% end %>
</ul>

<p>
  <%= link_to "Browse the full index", root_url %>
</p>

<p>— The XbutforY editors</p>

<% if @unsubscribe_url %>
  <hr>
  <p style="font-size: 12px; color: #777">
    Tired of us? <%= link_to "Unsubscribe", @unsubscribe_url %>.
  </p>
<% end %>
