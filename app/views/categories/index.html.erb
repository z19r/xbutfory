<% content_for :title, "Categories — XbutforY" %>
<% content_for :nav_tab, "categories" %>

<div class="l-categories">

  <div class="l-categories__heading">
    <h1 class="l-categories__title">Browse by Category</h1>
    <p class="l-categories__dek">7 categories &middot; pick one to filter the index</p>
  </div>

  <div class="l-categories__grid">
    <% @listings.each do |listing| %>
      <%= render CategoryTileComponent.new(
        name: listing[:category].name,
        slug: listing[:category].slug,
        count: listing[:count],
        color_token: listing[:category].color_token,
        short_code: listing[:category].short_code,
        sample: listing[:sample]
      ) %>
    <% end %>
  </div>
</div>
