<% if @sort == "trending" %>
  <% content_for :nav_tab, "trending" %>
<% elsif @sort == "top" %>
  <% content_for :nav_tab, "top" %>
<% elsif @sort == "random" %>
  <% content_for :nav_tab, "random" %>
<% end %>
<section class="l-hero" data-controller="idle-toast">
  <div class="l-issue"><span class="l-live"></span>VOL. 01 &middot; ISSUE 26 &middot; JUN 2026</div>

  <h1 class="l-dek">
    A hand-curated index of <i>newly launched</i> websites that pitch themselves as <code class="l-chip">X but for Y</code>. Updated daily, voted by humans.
  </h1>
  <div class="l-rule"></div>

  <%= render StatBlockComponent.new(
    new_today: @new_today,
    total_entries: @total_entries,
    categories_count: @categories_count
  ) %>
</section>

<% if @filter_category %>
  <div class="l-filter">
    <span class="l-filter__label">filtered:</span>
    <span class="l-filter__name"><%= @filter_category.name %></span>
    <%= link_to "×", root_path, class: "l-filter__clear", title: "clear filter", "aria-label": "Clear category filter" %>
  </div>
<% end %>

<div class="l-feedhead">
  <div>
    <h2 class="l-feedhead__title">Latest Submissions</h2>
    <div class="l-feedhead__sub">SHOWING 1&ndash;<%= @entries.size %> OF <%= @total_entries %></div>
  </div>
  <%= render SortToggleComponent.new(
    options: [
      SortToggleComponent::Option.new(label: "Newest", key: "newest"),
      SortToggleComponent::Option.new(label: "Hot", key: "trending"),
      SortToggleComponent::Option.new(label: "Top", key: "top")
    ],
    active: @sort
  ) %>
</div>

<div class="l-feed">
  <% position = 0 %>
  <% @entries.each do |entry| %>
    <% pinned = entry.sponsored == "pinned" %>
    <% position += 1 unless pinned %>
    <%= render EntryCardComponent.new(
      x: entry.x,
      y: entry.y,
      votes: entry.votes_count,
      description: entry.description,
      submitter: entry.submitter,
      ago: time_ago_in_words(entry.created_at) + " ago",
      url: entry.url.presence || "#",
      slug: entry.slug,
      index: (pinned ? nil : position),
      stamp: entry.stamp,
      sponsored: entry.sponsored,
      category: entry.category,
      category_label: entry.category&.titleize,
      entry_id: entry.id
    ) %>
  <% end %>

  <% if @entries.empty? %>
    <%= render EmptyStateComponent.new(title: "No entries yet. Be the first.", action: "Submit yours", action_url: "#") %>
  <% end %>
</div>
