<%= email_eyebrow "Milestone" %>

<h1 style="font-family: 'Newsreader', Georgia, serif; font-weight: 600; font-size: 23px; line-height: 1.18; margin: 0 0 12px; color: #171008;">
  <%= @milestone %> votes and counting.
</h1>

<p style="margin: 0 0 6px;">
  <%= @user.display_name.presence || "@#{@user.handle}" %>, your listing just
  crossed a line:
</p>

<p style="font-family: 'Newsreader', Georgia, serif; font-size: 20px; line-height: 1.2; margin: 0 0 18px; color: #171008;">
  <%= link_to @entry.title, entry_url(slug: @entry.slug), style: "color: #c93b1b; text-decoration: none;" %>
</p>

<p style="margin: 0 0 18px;">
  <strong style="font-weight: 600;"><%= @milestone %> votes.</strong> The readers
  have spoken; the formula holds.
</p>

<%= email_button "See where it stands", entry_url(slug: @entry.slug) %>

<p style="margin: 16px 0 0; font-size: 13px; color: #6b5d4a;">
  You get these because milestone notifications are on. Turn them off any time in
  <%= link_to "your settings", account_settings_url, style: "color: #c93b1b;" %>.
</p>
