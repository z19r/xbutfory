<%= email_eyebrow "Password reset" %>

<h1 style="font-family: 'Newsreader', Georgia, serif; font-weight: 600; font-size: 23px; line-height: 1.18; margin: 0 0 12px; color: #171008;">
  Pick a new password.
</h1>

<p style="margin: 0 0 18px;">
  Someone asked to reset the password for @<%= @user.handle %>. If that was you,
  choose a new one below — the link is good for 15 minutes.
</p>

<%= email_button "Reset your password", edit_password_reset_url(token: @token) %>

<p style="margin: 16px 0 0; font-size: 13px; color: #6b5d4a;">
  Didn&rsquo;t request this? Ignore this email — your password stays exactly as
  it is.
</p>
