<% content_for :title, "Submit a Site — XbutforY" %>
<% content_for :nav_tab, "submit" %>

<section class="c-submit" data-controller="submit-preview tier">
  <h1 class="c-submit__title">Submit a Site</h1>
  <p class="c-submit__dek">Free to list in the directory. $1.99 buys a featured homepage spot.</p>

  <% if @entry.errors.any? %>
    <div class="c-submit__errors">
      <strong><%= pluralize(@entry.errors.count, "thing") %> to fix:</strong>
      <ul>
        <% @entry.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @entry, url: submissions_path, class: "c-submit__form" do |f| %>
    <div class="c-submit__field">
      <%= f.label :x, "The X", class: "c-submit__label" %>
      <%= f.text_field :x, class: "c-submit__input", placeholder: "Tinder", autocomplete: "off",
            data: { submit_preview_target: "xInput", action: "input->submit-preview#update" } %>
    </div>

    <div class="c-submit__field">
      <%= f.label :y, "The Y", class: "c-submit__label" %>
      <%= f.text_field :y, class: "c-submit__input", placeholder: "the building you live in", autocomplete: "off",
            data: { submit_preview_target: "yInput", action: "input->submit-preview#update" } %>
    </div>

    <%= render SubmitPreviewComponent.new(x: @entry.x.to_s, y: @entry.y.to_s) %>

    <div class="c-submit__field">
      <%= f.label :name, "Product name", class: "c-submit__label" %>
      <%= f.text_field :name, class: "c-submit__input", placeholder: "Floormate", autocomplete: "off" %>
    </div>

    <div class="c-submit__field">
      <%= f.label :url, "Product URL", class: "c-submit__label" %>
      <%= f.url_field :url, class: "c-submit__input", placeholder: "https://…" %>
    </div>

    <div class="c-submit__field">
      <%= f.label :description, "One-line pitch (optional)", class: "c-submit__label" %>
      <%= f.text_area :description, rows: 2, class: "c-submit__input c-submit__textarea", placeholder: "What it does, in a sentence." %>
    </div>

    <div class="c-submit__field">
      <%= f.label :category, "Category", class: "c-submit__label" %>
      <%= f.select :category, @categories.map { |c| [c.name, c.slug] }, { include_blank: "Pick one" }, class: "c-submit__input c-submit__select" %>
    </div>

    <div class="c-submit__field">
      <%= f.label :submitter, "Your handle (optional)", class: "c-submit__label" %>
      <%= f.text_field :submitter, class: "c-submit__input", placeholder: "@you", autocomplete: "off" %>
    </div>

    <div class="c-submit__field">
      <span class="c-submit__label">Listing type</span>
      <div class="c-submit__tiers">
        <label class="c-submit__tier">
          <%= f.radio_button :tier, "free", checked: !@entry.featured?, class: "c-submit__tier-radio",
                data: { tier_target: "radio", action: "change->tier#update" } %>
          <span class="c-submit__tier-name">Free</span>
          <span class="c-submit__tier-desc">Indexed within 24h</span>
        </label>
        <label class="c-submit__tier">
          <%= f.radio_button :tier, "featured", checked: @entry.featured?, class: "c-submit__tier-radio",
                data: { tier_target: "radio", action: "change->tier#update" } %>
          <span class="c-submit__tier-name">Featured — $1.99</span>
          <span class="c-submit__tier-desc">Homepage spot + boost</span>
        </label>
      </div>
    </div>

    <%= f.submit (@entry.featured? ? "Launch for $1.99 →" : "Submit for free →"), class: "c-submit__cta", data: { tier_target: "cta" } %>
    <p class="c-submit__fine">no account needed &middot; no spam &middot; takes 30 seconds</p>
  <% end %>
</section>
