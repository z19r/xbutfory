<% content_for :nav_tab, "submit" %>
<div class="l-submit" data-controller="submit-preview">
  <div class="l-submit__form">
    <h1 class="l-submit__title">Submit an Entry</h1>
    <p class="l-submit__dek">Got a site that's <em>X but for Y</em>? Tell us about it.</p>

    <%= form_with(model: @entry, url: submissions_path, class: "c-submit-form") do |f| %>
      <% if @entry.errors.any? %>
        <div class="c-submit-form__errors">
          <p><%= pluralize(@entry.errors.count, "thing") %> went wrong:</p>
          <ul>
            <% @entry.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="c-submit-form__field">
        <%= f.label :x, "The X (the known product)", class: "c-submit-form__label" %>
        <%= f.text_field :x, class: "c-submit-form__input", placeholder: "e.g. Tinder", data: { action: "input->submit-preview#update", submit_preview_target: "xInput" } %>
      </div>

      <div class="c-submit-form__field">
        <%= f.label :y, "The Y (the niche)", class: "c-submit-form__label" %>
        <%= f.text_field :y, class: "c-submit-form__input", placeholder: "e.g. the building you live in", data: { action: "input->submit-preview#update", submit_preview_target: "yInput" } %>
      </div>

      <div class="c-submit-form__field">
        <%= f.label :description, "Pitch it (one paragraph)", class: "c-submit-form__label" %>
        <%= f.text_area :description, class: "c-submit-form__input c-submit-form__textarea", rows: 4, placeholder: "What is it, why does it work, and why should anyone care?" %>
      </div>

      <div class="c-submit-form__field">
        <%= f.label :url, "URL", class: "c-submit-form__label" %>
        <%= f.url_field :url, class: "c-submit-form__input", placeholder: "https://..." %>
      </div>

      <div class="c-submit-form__field">
        <%= f.label :submitter, "Your handle", class: "c-submit-form__label" %>
        <%= f.text_field :submitter, class: "c-submit-form__input", placeholder: "@yourtwitterhandle" %>
      </div>

      <div class="c-submit-form__field">
        <%= f.label :category, class: "c-submit-form__label" %>
        <%= f.select :category, Category.pluck(:name, :slug), { include_blank: "Pick a category" }, class: "c-submit-form__input" %>
      </div>

      <div class="c-submit-form__actions">
        <%= f.submit "Submit for review", class: "c-btn c-btn--primary c-btn--lg" %>
      </div>
    <% end %>
  </div>

  <div class="l-submit__preview">
    <%= render SubmitPreviewComponent.new %>
  </div>
</div>
