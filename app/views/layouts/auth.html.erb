<!DOCTYPE html>
<% accent = UtilityBarComponent.resolve_accent(cookies[:accent]) %>
<html style="--accent: var(--accent-<%= accent[:key] %>)">
  <head>
    <title><%= content_for(:title) || "XbutforY" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="is-auth">
    <%= render UtilityBarComponent.new(active_accent: accent[:key], current_user: current_user) %>

    <main class="l-auth">
      <%= yield %>
    </main>

    <%= render ToastComponent.new(message: flash[:alert] || flash[:notice]) %>
  </body>
</html>
