<% content_for :title, "Unsubscribed — XbutforY" %>
<div class="c-auth">
  <div class="c-auth__mark">
    <%= link_to root_path, class: "c-auth__wordmark", "aria-label": "XbutforY — home" do %>
      <%= render WordmarkComponent.new(size: 34, accent_y: false) %>
    <% end %>
  </div>

  <div class="c-auth-card">
    <% if @unsubscribed %>
      <div class="c-auth-card__eyebrow">UNSUBSCRIBED</div>
      <h1 class="c-auth-card__title">You're off the list.</h1>
      <p class="c-auth-card__lede">No more Sunday digests. The index carries on without you — no hard feelings.</p>
    <% else %>
      <div class="c-auth-card__eyebrow">DEAD LINK</div>
      <h1 class="c-auth-card__title">That link's expired.</h1>
      <p class="c-auth-card__lede">We couldn't match that unsubscribe link. You may already be off the list.</p>
    <% end %>

    <div class="c-auth-card__divider"><span>STILL CURIOUS?</span></div>
    <%= link_to "Back to the index", root_path, class: "c-auth-card__alt" %>
  </div>
</div>
