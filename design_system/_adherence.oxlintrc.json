{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/chrome/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/directory/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Space Mono|Outfit))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Space Mono, Outfit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|trailingArrow|disabled|type|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, trailingArrow, disabled, type, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|short|count|sample|category|color|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CategoryTile> doesn't accept that prop. Declared props: name, short, count, sample, category, color, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:dating|crm|discovery|saas|payments|social|logistics)$/]",
        "message": "<CategoryTile> category must be one of 'dating' | 'crm' | 'discovery' | 'saas' | 'payments' | 'social' | 'logistics'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<CodeChip> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|action|onAction|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: title, children, action, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|x|y|votes|voted|description|category|categoryLabel|submitter|ago|stamp|sponsored|url|onVote|onView|style|key|ref|className|style|children)$/]",
        "message": "<EntryCard> doesn't accept that prop. Declared props: index, x, y, votes, voted, description, category, categoryLabel, submitter, ago, stamp, sponsored, url, onVote, onView, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntryCard'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:dating|crm|discovery|saas|payments|social|logistics)$/]",
        "message": "<EntryCard> category must be one of 'dating' | 'crm' | 'discovery' | 'saas' | 'payments' | 'social' | 'logistics'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntryCard'] > JSXAttribute[name.name='stamp'] > Literal[value!=/^(?:NEW|HOT)$/]",
        "message": "<EntryCard> stamp must be one of 'NEW' | 'HOT'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntryCard'] > JSXAttribute[name.name='sponsored'] > Literal[value!=/^(?:pinned|spotlight)$/]",
        "message": "<EntryCard> sponsored must be one of 'pinned' | 'spotlight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MastheadBarLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|strong|key|ref|className|style|children)$/]",
        "message": "<MastheadBarLink> doesn't accept that prop. Declared props: label, strong."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|key|ref|className|style|children)$/]",
        "message": "<NavTab> doesn't accept that prop. Declared props: key, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, onChange, placeholder, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SortOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|key|ref|className|style|children)$/]",
        "message": "<SortOption> doesn't accept that prop. Declared props: key, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: kind, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:NEW|HOT)$/]",
        "message": "<Stamp> kind must be one of 'NEW' | 'HOT'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SubmitPreview'] > JSXAttribute > JSXIdentifier[name!=/^(?:x|y|label|style|key|ref|className|style|children)$/]",
        "message": "<SubmitPreview> doesn't accept that prop. Declared props: x, y, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|color|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: category, color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:dating|crm|discovery|saas|payments|social|logistics)$/]",
        "message": "<Tag> category must be one of 'dating' | 'crm' | 'discovery' | 'saas' | 'payments' | 'social' | 'logistics'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
